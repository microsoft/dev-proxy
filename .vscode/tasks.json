{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/msgraph-developer-proxy.sln",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "buildProxy",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/msgraph-developer-proxy/msgraph-developer-proxy.csproj",
        "-c",
        "Debug",
        "-p:PublishSingleFile=true",
        "--self-contained",
        "-r",
        "linux-x64",
        "-o",
        "${workspaceFolder}/msgraph-developer-proxy/bin/package"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "buildPlugins",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/msgraph-developer-proxy-plugins/msgraph-developer-proxy-plugins.csproj",
        "-c",
        "Debug",
        "--no-self-contained",
        "-o",
        "${workspaceFolder}/msgraph-developer-proxy/bin/package/GraphProxyPlugins"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build selfcontained",
      "dependsOrder": "sequence",
      // "dependsOn": ["buildProxy"]
      "dependsOn": ["build", "buildProxy", "buildPlugins"]
    },
    {
      "label": "publish",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/msgraph-developer-proxy.sln",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch",
      "command": "dotnet",
      "type": "process",
      "args": [
        "watch",
        "run",
        "--project",
        "${workspaceFolder}/msgraph-developer-proxy.sln"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
